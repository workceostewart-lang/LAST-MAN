{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "last-man",
  "compatibility_date": "2026-07-21",
  "routes": [
    {
      "pattern": "last-man.fantomzone.app",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
